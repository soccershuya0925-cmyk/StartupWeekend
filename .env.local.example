# OpenAI GPT-4o Vision API（レシート読み取り /receipt で使用）
# https://platform.openai.com/api-keys で取得して .env.local にコピーする
OPENAI_API_KEY=sk-xxxxxxxxxx

# Supabase（みんなの投稿フィード・ログイン・削除で使用）
# Supabase → Project Settings → API から取得。詳しくは docs/SUPABASE-SETUP.md
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxx
